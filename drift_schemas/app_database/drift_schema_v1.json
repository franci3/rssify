          "sql": "CREATE TABLE IF NOT EXISTS \"feed_items\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"title\" TEXT NOT NULL, \"description\" TEXT NOT NULL, \"link\" TEXT NOT NULL, \"published\" INTEGER NOT NULL, \"author\" TEXT NOT NULL, \"feed_id\" INTEGER NOT NULL REFERENCES feeds (id), \"hash\" TEXT NOT NULL UNIQUE, \"fetched_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), \"is_marked\" INTEGER NOT NULL CHECK (\"is_marked\" IN (0, 1)), \"was_read\" INTEGER NOT NULL CHECK (\"was_read\" IN (0, 1)));"
